    <validationRules>
        <fullName>Damage_Requires_Priority</fullName>
        <active>true</active>
        <description>Ensures Damage requires to case is high.</description>
        <errorConditionFormula>AND( OR( ISPICKVAL(Issue_Category__c, &quot;Warranty&quot;), ISPICKVAL(Issue_Category__c, &quot;Delivery&quot;) ), ISBLANK(TEXT(Priority__c)) )</errorConditionFormula>
        <errorDisplayField>Priority__c</errorDisplayField>
        <errorMessage>Priority is mandatory for Damage cases.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Warranty_Delivery_Requires_Priority</fullName>
        <active>true</active>
        <description>Ensures Warranty and Delivery requires priority.</description>
        <errorConditionFormula>AND( OR( ISPICKVAL(Issue_Category__c, &quot;Warranty&quot;), ISPICKVAL(Issue_Category__c, &quot;Delivery&quot;) ), ISBLANK(TEXT(Priority__c)) )</errorConditionFormula>
        <errorMessage>Priority is mandatory for Warranty and Delivery cases.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
